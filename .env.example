# ── Copier ce fichier en .env et adapter les valeurs ──────────────────────────

# Clé secrète Django — générez-en une avec :
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=remplacez-moi-par-une-vraie-cle-secrete

# False en production OBLIGATOIREMENT
DEBUG=False

# Votre domaine ou IP VPS (sans slash final)
# Exemple : monsite.com,www.monsite.com,123.45.67.89
ALLOWED_HOSTS=localhost,127.0.0.1

# Origines autorisées pour les requêtes CORS (votre frontend)
# Exemple : https://monsite.com,https://www.monsite.com
CORS_ALLOWED_ORIGINS=http://localhost,http://127.0.0.1
